{
  "name": "seam-lang",
  "version": "2.0.5",
  "description": "A small reasoning language with ISO Prolog-compatible surface syntax.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "seam": "./bin/seam.js"
  },
  "keywords": [
    "logic",
    "rules",
    "prolog",
    "reasoner",
    "proofs"
  ],
  "license": "MIT",
  "author": "Jos De Roo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyereasoner/seam.git"
  },
  "homepage": "https://github.com/eyereasoner/seam#readme",
  "files": [
    "LICENSE.md",
    "README.md",
    "index.js",
    "index.d.ts",
    "playground.html",
    "bin",
    "src",
    "conformance-report.md",
    "docs",
    "examples",
    "test"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node test/run-all.mjs",
    "test:seam": "node test/run-all.mjs",
    "test:conformance": "node test/run-conformance.mjs",
    "test:examples": "node test/run-examples.mjs",
    "test:regression": "node test/run-regression.mjs",
    "preversion": "npm test && npm run conformance:report -- conformance-report.md",
    "postversion": "git push origin HEAD --follow-tags",
    "conformance:report": "node test/run-conformance-report.mjs"
  }
}
