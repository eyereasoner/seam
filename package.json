{
  "name": "eyelang",
  "version": "1.7.11",
  "description": "A small Prolog-like logic programming language for rules, goals, answers, and proofs.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "eyelang": "./bin/eyelang.js"
  },
  "keywords": [
    "logic",
    "rules",
    "prolog",
    "reasoner",
    "proofs"
  ],
  "license": "MIT",
  "author": "Jos De Roo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyereasoner/eyelang.git"
  },
  "homepage": "https://github.com/eyereasoner/eyelang#readme",
  "files": [
    "LICENSE.md",
    "README.md",
    "index.js",
    "index.d.ts",
    "playground.html",
    "bin",
    "src",
    "conformance-report.md",
    "docs",
    "examples",
    "test"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node test/run-all.mjs",
    "test:eyelang": "node test/run-all.mjs",
    "test:conformance": "node test/run-conformance.mjs",
    "test:examples": "node test/run-examples.mjs",
    "test:regression": "node test/run-regression.mjs",
    "preversion": "npm test && npm run conformance:report -- conformance-report.md",
    "postversion": "git push origin HEAD --follow-tags",
    "conformance:report": "node test/run-conformance-report.mjs"
  }
}
